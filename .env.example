# Copia este archivo como `.env` y ajusta los valores según tu entorno.
# Ejemplo:
# cp .env.example .env

# URL base del backend Laravel (sin slash final)
# Web local:
# EXPO_PUBLIC_API_URL=http://localhost:8001
# Dispositivo físico (Expo Go):
# EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_API_URL=http://localhost:8001
